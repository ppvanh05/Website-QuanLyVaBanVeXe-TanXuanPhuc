# CẤU HÌNH MÔI TRƯỜNG AUTOMATION TEST (TXP LIMOUSINE)

# Môi trường chạy test (local, dev, staging)
NODE_ENV=local

# Địa chỉ URL ứng dụng khách hàng và quản trị
CUSTOMER_URL=http://localhost:4200
ADMIN_URL=http://localhost:4200/admin-login

# Tài khoản Admin mặc định để test
